```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
dist/
build/
target/

# Dependencies
.venv/
venv/
node_modules/
.julia/
zig*/
.jest/
.nyc_output/

# Logs and temp files
*.log
*.tmp
*.swp
*.swo
*.out

# Environment
.env
.env.local
.env.*

# Editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS generated files
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Python specific
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/

# Node.js specific
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
*.min.js
*.min.css
bundle.js
bundle.css

# Testing
.mypy_cache/
.pytest_cache/
.hypothesis/

# Gradle
.gradle/
build/

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```